# If running via Docker Compose, use the values below as-is.
# If using a hosted Postgres (e.g. Neon, Supabase, Railway), paste the
# connection string they give you instead.
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/ecommerce?schema=public"

# MongoDB Atlas example (remove the angle brackets around your password -
# they are just Atlas's placeholder syntax, not part of the real string.
# Special characters in the password must be URL-encoded, e.g. / -> %2F):
# MONGO_URI="mongodb+srv://<user>:<url-encoded-password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=ecommerce"
MONGO_URI="mongodb://mongo:27017/ecommerce_mongo"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
PORT=5000
CLIENT_URL="http://localhost:3000"
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_USER="replace-with-smtp-user"
SMTP_PASS="replace-with-smtp-pass"
